# Copy this file to .env.local and fill in all values before running the app.
# Never commit .env.local to version control.

# ─────────────────────────────────────────────────────────────
# Clerk — Authentication
# https://dashboard.clerk.com → your app → API Keys
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_

# Where Clerk redirects after sign-in (locale-aware redirects are handled
# in middleware, this is only the last-resort fallback)
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/en

# ─────────────────────────────────────────────────────────────
# Supabase — Database
# https://app.supabase.com → your project → Settings → API
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# Resend — Email
# https://resend.com → API Keys → Create API Key
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_

# The FROM address for approval emails.
# - Development: leave blank to use onboarding@resend.dev (sends to your
#   Resend account email only — free tier sandbox restriction).
# - Production: set to an address on your verified Resend domain,
#   e.g. noreply@yourdomain.com
RESEND_FROM_EMAIL=

# ─────────────────────────────────────────────────────────────
# App URL — used to build clickable links inside emails
# ─────────────────────────────────────────────────────────────
# Development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (update this before deploying)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
